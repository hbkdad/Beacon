# ============================================================
# SelfClawy — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- AI Provider (at least one required) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- OpenClaw Gateway ---
OPENCLAW_PORT=18789
# Generate with: openssl rand -hex 32
OPENCLAW_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- SelfClawy Dashboard ---
DASHBOARD_PORT=3001
DASHBOARD_PASSWORD=changeme

# --- Authentication mode ---
# 'basic' = single admin password (HTTP Basic Auth, default)
# 'jwt'   = multi-user accounts with JWT tokens (use for team access)
AUTH_MODE=basic
# Generate with: openssl rand -hex 32  (required when AUTH_MODE=jwt)
JWT_SECRET=

# --- Alerting ---
# Paste a Discord webhook URL or Telegram bot API URL here.
# You'll get a message when OpenClaw/Hermes goes online or offline.
ALERT_WEBHOOK_URL=

# --- Channel tokens (optional — add only what you use) ---
TELEGRAM_TOKEN=
DISCORD_TOKEN=
# WhatsApp / Signal: linked via QR code on first run — no token needed

# --- Security ---
# Comma-separated E.164 phone numbers allowed to message your bot
OPENCLAW_ALLOW_FROM=+15555550123

# ============================================================
# Optional backends — controlled by COMPOSE_PROFILES
# ============================================================
# Leave blank for OpenClaw only (default)
# Examples:
#   COMPOSE_PROFILES=hermes
#   COMPOSE_PROFILES=ollama
#   COMPOSE_PROFILES=hermes,ollama
# Run with autoupdates: COMPOSE_PROFILES=autoupdate
COMPOSE_PROFILES=

# --- Hermes Agent (enabled when COMPOSE_PROFILES includes 'hermes') ---
HERMES_PORT=8080
# Generate with: openssl rand -hex 32
HERMES_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# Set to http://ollama:11434 to use local Ollama models in Hermes
OLLAMA_BASE_URL=

# --- Ollama local model runner (enabled when COMPOSE_PROFILES includes 'ollama') ---
OLLAMA_PORT=11434
# GPU: run with docker-compose.gpu.yml override if you have an NVIDIA GPU:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
