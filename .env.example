# ============================================================
# SelfClawy — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- AI Provider (at least one required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- OpenClaw Gateway ---
OPENCLAW_PORT=18789
# Generate with: openssl rand -hex 32
OPENCLAW_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- SelfClawy Dashboard ---
DASHBOARD_PORT=3001
DASHBOARD_PASSWORD=changeme

# --- Channel tokens (optional — add only what you use) ---
# Telegram: get from @BotFather
TELEGRAM_TOKEN=

# Discord: https://discord.com/developers/applications
DISCORD_TOKEN=

# WhatsApp: scanned via QR code on first run — no token needed

# Signal: linked via QR code on first run — no token needed

# --- Security ---
# Comma-separated E.164 phone numbers allowed to message your bot
# Leave blank to allow any sender (NOT recommended)
OPENCLAW_ALLOW_FROM=+15555550123
